# =============================================================================
# Full Stack Human — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Get these from: https://supabase.com/dashboard → Project Settings → API
# -----------------------------------------------------------------------------

# Your Supabase project URL (public, safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (public, safe for client-side)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase service role key (secret — server-side only)
# Has full access to all tables, bypasses RLS. Never expose to the client.
SUPABASE_SECRET_KEY=

# -----------------------------------------------------------------------------
# Anthropic (Claude API)
# Get your key from: https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------

# API key for Claude conversations
ANTHROPIC_API_KEY=

# Optional: override the default model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Enable web search for AI conversations (server-side Anthropic tool).
# When enabled, the AI can search the web for current tool/product info.
# Cost: billed per search via Anthropic. Default: disabled.
# ANTHROPIC_ENABLE_WEB_SEARCH=true

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------

# Public-facing app URL — used for metadata, sitemap, robots.txt, OG tags,
# and auth callbacks (email confirmation, password reset, OAuth redirect).
# Must match the Site URL configured in Supabase Auth settings.
# Default: https://fullstackhuman.sh
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# PostHog Analytics
# Get your key from: https://eu.posthog.com/settings/project#variables
# -----------------------------------------------------------------------------

# PostHog project API key (public, safe for client-side)
NEXT_PUBLIC_POSTHOG_KEY=

# PostHog API host (default: EU cloud — GDPR compliant)
# EU cloud: https://eu.i.posthog.com | US cloud: https://us.i.posthog.com
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# -----------------------------------------------------------------------------
# Upstash Redis (Rate Limiting)
# Create a database at: https://console.upstash.com/redis
# Select EU (Frankfurt) region for GDPR compliance.
# Free tier: 10K commands/day — sufficient for rate limiting.
# Optional: rate limiting falls back to in-memory if not configured.
# -----------------------------------------------------------------------------

# Upstash Redis REST URL (server-side only)
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token (server-side only, secret)
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# Salt for hashing IP addresses in logs (server-side only, secret).
# Used to anonymize IPs while allowing correlation across requests.
# REQUIRED in production — logs a warning if missing.
# Generate with: openssl rand -hex 32
LOG_HASH_SALT=

# -----------------------------------------------------------------------------
# Telegram Bot
# Create a bot via @BotFather on Telegram: https://t.me/BotFather
# Optional: bot is disabled if these are not set.
# -----------------------------------------------------------------------------

# Bot token from @BotFather (server-side only, secret)
TELEGRAM_BOT_TOKEN=

# Random secret for webhook verification (server-side only, secret)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELEGRAM_WEBHOOK_SECRET=

# Public webhook URL — must be HTTPS in production
# Example: https://fullstackhuman.sh/api/telegram/webhook
TELEGRAM_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Email (ImprovMX SMTP)
# Used for booking confirmation, notification, and cancellation emails.
# Optional: emails are skipped if SMTP is not configured.
# -----------------------------------------------------------------------------

# SMTP server host (ImprovMX: smtp.improvmx.com)
SMTP_HOST=

# SMTP server port (default: 587)
# SMTP_PORT=587

# SMTP authentication credentials (server-side only, secret)
SMTP_USER=
SMTP_PASS=

# Sender address for outgoing emails
# Example: FullStackHuman <booking@fullstackhuman.sh>
SMTP_FROM=

# -----------------------------------------------------------------------------
# Google Calendar
# Used for booking integration — creates events and checks availability.
# Set up OAuth 2.0 credentials at: https://console.cloud.google.com/apis/credentials
# Required scopes: https://www.googleapis.com/auth/calendar
# Optional: bookings work without Google Calendar (no event creation or FreeBusy check).
# -----------------------------------------------------------------------------

# OAuth 2.0 client credentials (server-side only, secret)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth redirect URI — must match the one configured in Google Console
# Example: https://fullstackhuman.sh/api/booking/google/callback
GOOGLE_REDIRECT_URI=

# Calendar ID to create events in (usually your primary email)
# Example: francois@fullstackhuman.sh
GOOGLE_CALENDAR_ID=

# -----------------------------------------------------------------------------
# Turing Game (Partykit)
# Real-time multiplayer game where players try to identify AI agents.
# Partykit runs as a separate WebSocket server on Cloudflare Workers.
# Optional: game features are disabled if not configured.
# -----------------------------------------------------------------------------

# Partykit server host (public, client-side — used for WebSocket connections)
# Local: localhost:1999 | Production: your-project.username.partykit.dev
NEXT_PUBLIC_PARTYKIT_HOST=localhost:1999

# Next.js app URL for Partykit→Next.js server-to-server calls (moderation API)
# Must be reachable from the Partykit server.
# Local: http://localhost:3000 | Production: https://fullstackhuman.sh
NEXTJS_URL=http://localhost:3000

# Shared secret for Partykit↔Next.js internal API authentication (server-side, secret)
# Secures the moderation endpoint (/api/game/moderate).
# Generate with: openssl rand -hex 32
GAME_INTERNAL_TOKEN=<generate-with-openssl-rand-hex-32>
