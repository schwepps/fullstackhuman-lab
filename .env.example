# =============================================================================
# Full Stack Human — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Get these from: https://supabase.com/dashboard → Project Settings → API
# -----------------------------------------------------------------------------

# Your Supabase project URL (public, safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (public, safe for client-side)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase service role key (secret — server-side only)
# Has full access to all tables, bypasses RLS. Never expose to the client.
SUPABASE_SECRET_KEY=

# -----------------------------------------------------------------------------
# Anthropic (Claude API)
# Get your key from: https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------

# API key for Claude conversations
ANTHROPIC_API_KEY=

# Optional: override the default model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------

# Public-facing app URL — used for metadata, sitemap, robots.txt, OG tags,
# and auth callbacks (email confirmation, password reset, OAuth redirect).
# Must match the Site URL configured in Supabase Auth settings.
# Default: https://fullstackhuman.sh
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# PostHog Analytics
# Get your key from: https://eu.posthog.com/settings/project#variables
# -----------------------------------------------------------------------------

# PostHog project API key (public, safe for client-side)
NEXT_PUBLIC_POSTHOG_KEY=

# PostHog API host (default: EU cloud — GDPR compliant)
# EU cloud: https://eu.i.posthog.com | US cloud: https://us.i.posthog.com
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# -----------------------------------------------------------------------------
# Upstash Redis (Rate Limiting)
# Create a database at: https://console.upstash.com/redis
# Select EU (Frankfurt) region for GDPR compliance.
# Free tier: 10K commands/day — sufficient for rate limiting.
# Optional: rate limiting falls back to in-memory if not configured.
# -----------------------------------------------------------------------------

# Upstash Redis REST URL (server-side only)
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token (server-side only, secret)
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# Salt for hashing IP addresses in logs (server-side only, secret).
# Used to anonymize IPs while allowing correlation across requests.
# REQUIRED in production — logs a warning if missing.
# Generate with: openssl rand -hex 32
LOG_HASH_SALT=

# -----------------------------------------------------------------------------
# Telegram Bot
# Create a bot via @BotFather on Telegram: https://t.me/BotFather
# Optional: bot is disabled if these are not set.
# -----------------------------------------------------------------------------

# Bot token from @BotFather (server-side only, secret)
TELEGRAM_BOT_TOKEN=

# Random secret for webhook verification (server-side only, secret)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELEGRAM_WEBHOOK_SECRET=

# Public webhook URL — must be HTTPS in production
# Example: https://fullstackhuman.sh/api/telegram/webhook
TELEGRAM_WEBHOOK_URL=
