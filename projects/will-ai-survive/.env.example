# Claude API — required for AI evaluation and moderation
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Upstash Redis — required for rate limiting and result storage
# Create a free database at https://console.upstash.com/
# Select EU (Frankfurt) region for GDPR compliance
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Site URL — optional, auto-detected on Vercel
# Set this for production deployments outside Vercel
# Omit for local dev (defaults to http://localhost:3000)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
