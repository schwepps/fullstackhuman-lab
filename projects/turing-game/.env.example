# Anthropic API (AI agents in Partykit)
ANTHROPIC_API_KEY=

# Upstash Redis (rate limiting + room store)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Partykit WebSocket host (client-side)
NEXT_PUBLIC_PARTYKIT_HOST=localhost:1999

# Internal token for Partykit → Next.js moderation API
GAME_INTERNAL_TOKEN=

# Next.js URL (used by Partykit to call moderation API)
NEXTJS_URL=http://localhost:3000
