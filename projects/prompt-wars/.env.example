# Claude API — required for AI defense responses
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Upstash Redis — required for rate limiting, caching, leaderboard
# Create a free database at https://console.upstash.com/
# Select EU (Frankfurt) region for GDPR compliance
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Level secrets — CHANGE THESE before deploying
LEVEL_1_SECRET=CHANGE-ME-1
LEVEL_2_SECRET=CHANGE-ME-2
LEVEL_3_SECRET=CHANGE-ME-3
LEVEL_4_SECRET=CHANGE-ME-4
LEVEL_5_SECRET=CHANGE-ME-5
LEVEL_6_SECRET=CHANGE-ME-6
LEVEL_7_SECRET=CHANGE-ME-7

# Kill switch — set to "true" to disable all API calls (maintenance mode)
# DISABLE_API_CALLS=true
