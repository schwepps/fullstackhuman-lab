# Claude API — required for AI defense responses
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Upstash Redis — required for rate limiting, caching, leaderboard
# Create a free database at https://console.upstash.com/
# Select EU (Frankfurt) region for GDPR compliance
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Level secrets — rotate these to reset player progress
LEVEL_1_SECRET=RAINBOW-42
LEVEL_2_SECRET=THUNDER-99
LEVEL_3_SECRET=CRYSTAL-17
LEVEL_4_SECRET=NEBULA-55
LEVEL_5_SECRET=ZENITH-88
LEVEL_6_SECRET=PRISM-33
LEVEL_7_SECRET=ECLIPSE-77

# Kill switch — set to "true" to disable all API calls (maintenance mode)
# DISABLE_API_CALLS=true
