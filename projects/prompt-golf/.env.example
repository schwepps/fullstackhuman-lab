# Claude API — required for code generation + AI judge
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Upstash Redis — required for rate limiting, results, leaderboard
# Create a free database at https://console.upstash.com/
# Select EU (Frankfurt) region for GDPR compliance
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Kill switch — set to "true" to disable all API calls (maintenance mode)
# DISABLE_API_CALLS=true
